<ruleset xmlns:xsi="http://w3.org" name="PHPLab_PSR-16" xsi:noNamespaceSchemaLocation="vendor/squizlabs/php_codesniffer/phpcs.xsd">
    <description>Ruleset for PSR-16 Simple Cache</description>

    <arg name="colors"/>
    <arg value="sp"/>
    <arg name="extensions" value="php"/>

    <config name="installed_paths" value="/var/www/vendor/squizlabs/php_codesniffer/src/Standards"/>

    <file>src</file>
    <file>tests</file>

    <exclude-pattern>./tests/fixtures/*</exclude-pattern>

    <rule ref="PSR12"/>
</ruleset>